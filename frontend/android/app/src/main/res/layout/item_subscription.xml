<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_card_white"
    android:padding="12dp"
    android:orientation="horizontal">

    <FrameLayout
        android:id="@+id/sub_icon_box"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_icon_black">
        <TextView
            android:id="@+id/sub_icon_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Я"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/sub_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Подписка"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/sub_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status_active"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Активна"
            android:textSize="11sp"
            android:textColor="#1B7F2A" />

        <TextView
            android:id="@+id/sub_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Категория"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/sub_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="399 ₽"
            android:textStyle="bold"
            android:textColor="@color/primary_purple" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="end">

        <ImageView
            android:id="@+id/sub_menu"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_more" />

        <TextView
            android:id="@+id/sub_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 мар."
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>
