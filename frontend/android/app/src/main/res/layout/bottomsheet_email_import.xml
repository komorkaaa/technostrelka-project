<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/email_import_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F6F5F8">

    <TextView
        android:id="@+id/btn_close"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="@drawable/bg_chip"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center"
        android:text="Закрыть"
        android:textColor="@color/primary_purple"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Импорт почты"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Источник"
        android:textColor="@color/text_secondary"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_white"
        android:padding="12dp">

        <TextView
            android:id="@+id/label_demo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Использовать демо-данные"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <Switch
            android:id="@+id/switch_demo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Провайдер"
        android:textColor="@color/text_secondary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_white"
        android:padding="12dp">

        <RadioGroup
            android:id="@+id/provider_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/provider_gmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Gmail"/>

            <RadioButton
                android:id="@+id/provider_mailru"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Mail.ru"/>

            <RadioButton
                android:id="@+id/provider_yandex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Yandex"/>

            <RadioButton
                android:id="@+id/provider_outlook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Outlook"/>
        </RadioGroup>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Почтовые данные"
        android:textColor="@color/text_secondary"/>

    <LinearLayout
        android:id="@+id/email_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_white"
        android:padding="12dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/edit_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Email"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:inputType="textEmailAddress"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE"/>

        <EditText
            android:id="@+id/edit_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:hint="Пароль приложения"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:inputType="textPassword"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Согласен использовать пароль"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <Switch
                android:id="@+id/switch_consent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="IMAP настройки"
        android:textColor="@color/text_secondary"/>

    <LinearLayout
        android:id="@+id/imap_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_white"
        android:padding="12dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/edit_imap"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="imap.gmail.com"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:inputType="text"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE"/>

        <EditText
            android:id="@+id/edit_mailbox"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:hint="INBOX"
            android:background="@android:color/transparent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center_vertical"
            android:inputType="text"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/limit_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Лимит:"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/limit_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/limit_label"
                android:layout_marginStart="6dp"
                android:text="20"
                android:textColor="@color/text_primary"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_limit_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:text="-"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <TextView
                    android:id="@+id/btn_limit_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btn_import"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_white"
        android:gravity="center"
        android:text="Импортировать"
        android:textColor="@color/primary_purple"
        android:textStyle="bold"/>
</LinearLayout>
