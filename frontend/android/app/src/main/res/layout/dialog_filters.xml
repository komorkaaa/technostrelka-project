<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Категории"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/filter_categories_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Период"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/filter_period_monthly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly" />

        <CheckBox
            android:id="@+id/filter_period_weekly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly" />

        <CheckBox
            android:id="@+id/filter_period_yearly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yearly" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Цена"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/filter_price_min"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Мин"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/filter_price_max"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Макс"
            android:inputType="numberDecimal" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>