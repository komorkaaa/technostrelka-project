<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_sub_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_black">

            <TextView
                android:id="@+id/dialog_sub_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="?"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialog_sub_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Подписка"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/dialog_sub_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_status_active"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Активна"
                android:textSize="11sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/dialog_sub_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 мар."
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/dialog_sub_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Категория: Стриминг"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/dialog_sub_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Сумма: 399 ₽"
        android:textStyle="bold"
        android:textColor="@color/primary_purple" />

    <TextView
        android:id="@+id/dialog_sub_next_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Следующее списание: 20 мар."
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/action_edit"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_category"
        android:gravity="center"
        android:text="Редактировать"
        android:textColor="@color/primary_purple"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/action_pause"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_category"
            android:gravity="center"
            android:text="Поставить на паузу"
            android:textColor="@color/primary_purple"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/action_delete"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_category_badge"
            android:gravity="center"
            android:text="Удалить"
            android:textColor="@color/primary_purple"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
